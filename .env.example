# === Vichaar-Core Environment Variables ===
# Copy this file to .env and fill in your values.
# The system works WITHOUT any API key (heuristic fallback mode).

# Hugging Face token (recommended for HF Spaces deployment)
HF_TOKEN=

# Alternative: OpenAI-compatible API (OpenRouter, OpenAI, etc.)
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# API endpoint (defaults to HuggingFace Inference API if unset)
API_BASE_URL=
OPENAI_API_BASE=

# Model name (defaults to meta-llama/Llama-3.1-8B-Instruct if unset)
MODEL_NAME=
