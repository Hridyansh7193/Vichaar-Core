# === Vichaar-Core Environment Variables ===
# Copy this file to .env and fill in your values.
# The system works WITHOUT any API key (heuristic fallback mode).

# Hugging Face token (recommended for HF Spaces deployment)
HF_TOKEN=

# Alternative: OpenAI-compatible API
OPENAI_API_KEY=
API_BASE_URL=
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
